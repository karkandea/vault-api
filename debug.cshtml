@using APS_WEB_APP.Models;

@{
    ApprovalRequestModel.ApprovalRequestProcSum approvalProcSum = (ApprovalRequestModel.ApprovalRequestProcSum)ViewBag.PRFSummaryApproval;

    ApprovalRequestGroupModel.ApprovalRequestGroupProcSum approvalNonBudget = null;
    ApprovalRequestGroupModel.ApprovalRequestGroupProcSum approvalManagerHOP = null;
    ApprovalRequestGroupModel.ApprovalRequestGroupProcSum approvalHOP = null;
    ApprovalRequestGroupModel.ApprovalRequestGroupProcSum approvalRequestor = null;
    ApprovalRequestGroupModel.ApprovalRequestGroupProcSum approvalAdditional = null;
    ApprovalRequestGroupModel.ApprovalRequestGroupProcSum approvalHOU = null;
    ApprovalRequestGroupModel.ApprovalRequestGroupProcSum approvalDAP = null;
    List<string> itemNameList = null;
    ApprovalRequestGroupModel.ApprovalRequestGroupProcSum approvalCreator = null;

    if (approvalProcSum != null && approvalProcSum.ApprovalRequestGroupList.Count > 0)
    {
        approvalNonBudget = approvalProcSum.ApprovalRequestGroupList.SingleOrDefault(x => x.ApprovalGroupSubCategoryName.ToLower().Contains("non-budget"));
        approvalManagerHOP = approvalProcSum.ApprovalRequestGroupList.SingleOrDefault(x => x.ApprovalGroupSubCategoryName.ToLower().Contains("procsum-manager-hop"));
        approvalHOP = approvalProcSum.ApprovalRequestGroupList.SingleOrDefault(x => x.ApprovalGroupSubCategoryName.ToLower().Contains("procsum-hop"));
        approvalRequestor = approvalProcSum.ApprovalRequestGroupList.SingleOrDefault(x => x.ApprovalGroupSubCategoryName.ToLower().Contains("procsum-requestor"));
        approvalAdditional = approvalProcSum.ApprovalRequestGroupList.SingleOrDefault(x => x.ApprovalGroupSubCategoryName.ToLower().Contains("procsum-additional"));
        approvalHOU = approvalProcSum.ApprovalRequestGroupList.SingleOrDefault(x => x.ApprovalGroupSubCategoryName.ToLower().Contains("hou"));
        approvalDAP = approvalProcSum.ApprovalRequestGroupList.SingleOrDefault(x => x.ApprovalGroupSubCategoryName.ToLower().Contains("cart - request"));
        if (approvalDAP?.ApprovalRequestGroupMemberList?.Count > 0)
        {
            itemNameList = approvalDAP.ApprovalRequestGroupMemberList.Select(x => x.ItemDescription).Distinct().ToList();
        }
        approvalCreator = approvalProcSum.ApprovalRequestGroupList.SingleOrDefault(x => x.ApprovalGroupSubCategoryName.ToLower().Contains("procsum-creator"));
    }
    VendorCandidateDetails vcd = ViewBag.CandidatVendor;
}


