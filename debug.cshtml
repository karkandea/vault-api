                            {
                                <tr>
                                    <td>@member.BusinessUnitName</td>
                                    <td>@member.CostCenterName</td>
                                    <td>@member.UserName</td>
                                    <td><div class="@(member.StatusName)Status">@member.StatusName</div></td>
