# Database
ConnectionStrings__DefaultConnection=Host=YOUR_HOST;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# JWT
Jwt__Secret=your-jwt-secret-key-minimum-32-characters-replace-this
Jwt__Issuer=vault-api
Jwt__Audience=vault-client
Jwt__ExpiryHours=24

# CORS
AllowedOrigins__0=http://localhost:5173
AllowedOrigins__1=http://127.0.0.1:5173
